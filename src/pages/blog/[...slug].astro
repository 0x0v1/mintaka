---
import { getCollection } from "astro:content";
import type { AstroSeoProps } from "@astrolib/seo";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";

export async function getStaticPaths() {
	const blogEntries = await getCollection("posts");

	return blogEntries
		.map((entry) => {
			const [lang, ...slug] = entry.slug.split("/");
			return { params: { lang, slug: slug.join("/") || undefined }, props: entry };
		})
		.filter((entry) => entry.params.lang === "en");
}

const entry = Astro.props;
const { Content } = await entry.render();
const site = Astro.site ?? "https://barghest.asia";
const slug = Astro.params.slug ?? "";
const seoTitle = entry.data.seoTitle ?? entry.data.title;
const seoDescription = entry.data.seoDescription ?? entry.data.description;
const canonical = new URL(`/blog/${slug}/`, site).toString();
const ogImage = entry.data.socialImage
	? {
			url: new URL(entry.data.socialImage, site).toString(),
			width: 1200,
			height: 630,
			alt: `${seoTitle} — Read the full write-up`,
			type: "image/png",
		}
	: {
			url: new URL(entry.data.image.source.src, site).toString(),
			width: entry.data.image.source.width,
			height: entry.data.image.source.height,
			alt: entry.data.image.alt,
		};

const seo: AstroSeoProps = {
	title: seoTitle,
	description: seoDescription,
	canonical,
	openGraph: {
		url: canonical,
		title: seoTitle,
		description: seoDescription,
		images: [ogImage],
		site_name: "Barghest",
	},
};
---

<MarkdownPostLayout frontmatter={entry.data} body={entry.body} seo={seo}>
	<Content />
</MarkdownPostLayout>
